	url = https://github.com/lchansson/nordstatextras
[submodule "pixieweb"]
	path = pixieweb
	url = https://github.com/lchansson/pixieweb
[submodule "rKolada"]
	path = rKolada
	url = https://github.com/lchansson/rkolada
